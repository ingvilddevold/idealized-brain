<?xml version="1.0"?>
<!DOCTYPE Xdmf SYSTEM "Xdmf.dtd" []>
<Xdmf Version="3.0" xmlns:xi="https://www.w3.org/2001/XInclude">
  <Domain>
    <Grid Name="mesh" GridType="Uniform">
      <Topology TopologyType="Tetrahedron" NumberOfElements="16704" NodesPerElement="4">
        <DataItem Dimensions="16704 4" NumberType="Int" Format="HDF">mesh.h5:/Mesh/mesh/topology</DataItem>
      </Topology>
      <Geometry GeometryType="XYZ">
        <DataItem Dimensions="3377 3" Format="HDF">mesh.h5:/Mesh/mesh/geometry</DataItem>
      </Geometry>
    </Grid>
    <Grid Name="subdomains" GridType="Uniform">
      <xi:include xpointer="xpointer(/Xdmf/Domain/Grid/Geometry)" />
      <Topology TopologyType="Tetrahedron" NumberOfElements="16704" NodesPerElement="4">
        <DataItem Dimensions="16704 4" NumberType="Int" Format="HDF">mesh.h5:/MeshTags/subdomains/topology</DataItem>
      </Topology>
      <Attribute Name="subdomains" AttributeType="Scalar" Center="Cell">
        <DataItem Dimensions="16704 1" Format="HDF">mesh.h5:/MeshTags/subdomains/Values</DataItem>
      </Attribute>
    </Grid>
    <Grid Name="subdomains_ftetwild" GridType="Uniform">
      <xi:include xpointer="xpointer(/Xdmf/Domain/Grid/Geometry)" />
      <Topology TopologyType="Tetrahedron" NumberOfElements="16704" NodesPerElement="4">
        <DataItem Dimensions="16704 4" NumberType="Int" Format="HDF">mesh.h5:/MeshTags/subdomains_ftetwild/topology</DataItem>
      </Topology>
      <Attribute Name="subdomains_ftetwild" AttributeType="Scalar" Center="Cell">
        <DataItem Dimensions="16704 1" Format="HDF">mesh.h5:/MeshTags/subdomains_ftetwild/Values</DataItem>
      </Attribute>
    </Grid>
    <Grid Name="boundaries" GridType="Uniform">
      <xi:include xpointer="xpointer(/Xdmf/Domain/Grid/Geometry)" />
      <Topology TopologyType="Triangle" NumberOfElements="4166" NodesPerElement="3">
        <DataItem Dimensions="4166 3" NumberType="Int" Format="HDF">mesh.h5:/MeshTags/boundaries/topology</DataItem>
      </Topology>
      <Attribute Name="boundaries" AttributeType="Scalar" Center="Cell">
        <DataItem Dimensions="4166 1" Format="HDF">mesh.h5:/MeshTags/boundaries/Values</DataItem>
      </Attribute>
    </Grid>
  </Domain>
</Xdmf>
